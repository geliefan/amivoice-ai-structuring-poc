# =============================================================================
# amivoice-ai-structuring-poc - environment variables
#
# Copy this file to `.env.local` and fill in the values you need.
# `.env.local` is gitignored and must never be committed.
#
# All keys here are read on the SERVER ONLY (Next.js API Routes / lib).
# Do NOT prefix any of these with NEXT_PUBLIC_, which would expose them
# to the browser.
# =============================================================================

# --- AmiVoice ---------------------------------------------------------------

# AmiVoice API key. Leave empty to use the mock transcription provider.
AMIVOICE_API_KEY=

# Sync HTTP recognition endpoint.
#  - No log retention (default): https://acp-api.amivoice.com/v1/nolog/recognize
#  - With log retention:         https://acp-api.amivoice.com/v1/recognize
AMIVOICE_API_ENDPOINT=https://acp-api.amivoice.com/v1/nolog/recognize

# Grammar file names passed in the `d` request parameter.
AMIVOICE_GRAMMAR_FILE_NAMES=-a-general

# Whether to keep filler tokens (e.g. "えーと", "あの") in the transcription.
# 0 = remove fillers (default, recommended for structuring)
# 1 = keep fillers (useful when analyzing hesitation/emotion in the speech)
AMIVOICE_KEEP_FILLER_TOKEN=0

# --- Gemini ------------------------------------------------------------------

# Gemini API key. Leave empty to use the mock LLM provider.
GEMINI_API_KEY=

# Set a model available in your Gemini API project.
# Example: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# --- Provider selection -------------------------------------------------------

# Transcription provider: mock | amivoice
# Falls back to "mock" automatically if AMIVOICE_API_KEY is not set.
TRANSCRIPTION_PROVIDER=mock

# LLM provider: mock | gemini
# Falls back to "mock" automatically if GEMINI_API_KEY is not set.
LLM_PROVIDER=mock
